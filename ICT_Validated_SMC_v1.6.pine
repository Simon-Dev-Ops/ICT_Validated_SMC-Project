// This Pine Script™ code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// © Validated ICT / Smart Money Concepts Indicator v1.6
// "Don't just label. Validate."
//
// v1.6 — Real-time structure detection:
//  - BOS/CHoCH now registers on the bar where price actually crosses the swing level,
//    instead of waiting for the next pivot to confirm (~Swing Length bars late, which
//    could label breaks in the direction of the leg that had just ended at reversals)
//  - Trend state flips on the break bar; BOS/CHoCH alerts fire on that bar's close
//  - "Require Body Close" now genuinely selects close-through vs wick-through breaks
//  - Same real-time logic applied to HTF structure and internal structure
//
// v1.5 — Bugfix release:
//  - Fixed runtime crash in EQH/EQL and BPR scans (negative array index when few pivots/FVGs exist)
//  - Fixed runtime crash in OB displacement check for Swing Length <= 6 (negative history offset)
//  - Fixed swapped displacement (FVG) direction check in OB validation
//  - Breakers/IFVGs no longer count their creation bar as a "retest"
//  - Detection logic decoupled from display toggles (hiding OBs/FVGs/OTE/structure no longer kills signals)
//  - Same-bar swing high + swing low pivots are now both processed
//  - Long and short signals no longer share SL/TP variables
//  - EQH/EQL drawings are now tracked and capped; removed dead code

//@version=6
indicator("ICT Validated SMC v1", "ICT-V", overlay=true, max_labels_count=500, max_lines_count=500, max_boxes_count=500)

// ============================================================================
// INPUTS
// ============================================================================

// === Structure Detection ===
structGroup = "Market Structure"
swingLen = input.int(10, "Swing Length", minval=3, maxval=50, group=structGroup, tooltip="Bars to confirm swing highs/lows. Lower = more sensitive")
internalLen = input.int(5, "Internal Structure Length", minval=2, maxval=30, group=structGroup, tooltip="For internal BOS/CHoCH detection")
showSwings = input.bool(true, "Show Swing Points", group=structGroup)
showStructure = input.bool(true, "Show BOS / CHoCH", group=structGroup)
showInternalStructure = input.bool(false, "Show Internal Structure", group=structGroup)
requireBodyClose = input.bool(false, "Require Body Close for BOS/CHoCH", group=structGroup, tooltip="When enabled, structure breaks are only confirmed when the candle body closes beyond the level, not just wicks through. More conservative but higher conviction")

// === Higher Timeframe ===
htfGroup = "Higher Timeframe Alignment"
useHTF = input.bool(true, "Enable HTF Structure Check", group=htfGroup, tooltip="Check higher timeframe structure to validate setups")
htfTimeframe = input.timeframe("240", "HTF Timeframe", group=htfGroup, tooltip="Higher timeframe for structure alignment (e.g. 240 = 4H, D = Daily)")
htfSwingLen = input.int(10, "HTF Swing Length", minval=3, maxval=50, group=htfGroup)
showHTFStructure = input.bool(true, "Show HTF Structure on Chart", group=htfGroup, tooltip="Draw HTF swing levels and structure direction")

// === Order Blocks ===
obGroup = "Order Blocks"
showOB = input.bool(true, "Show Order Blocks", group=obGroup)
obMaxCount = input.int(5, "Max Visible OBs", minval=1, maxval=20, group=obGroup)
requireSweep = input.bool(true, "Require Liquidity Sweep", group=obGroup, tooltip="Only show OBs preceded by a candle sweep — strict ICT validation")
requireDisplacement = input.bool(true, "Require Displacement (FVG)", group=obGroup, tooltip="Only show OBs followed by an impulsive move leaving an FVG")
showMitigated = input.bool(false, "Show Mitigated OBs", group=obGroup, tooltip="Keep showing OBs after price trades through them")

// === Breaker Blocks ===
brkGroup = "Breaker Blocks"
showBreakers = input.bool(true, "Show Breaker Blocks", group=brkGroup, tooltip="Failed OBs that flip direction — one of ICT's strongest levels")
brkMaxCount = input.int(5, "Max Visible Breakers", minval=1, maxval=15, group=brkGroup)
brkBullColor = input.color(color.new(#00E676, 75), "Bullish Breaker Fill", group=brkGroup)
brkBearColor = input.color(color.new(#FF6D00, 75), "Bearish Breaker Fill", group=brkGroup)

// === Fair Value Gaps ===
fvgGroup = "Fair Value Gaps"
showFVG = input.bool(true, "Show FVGs", group=fvgGroup)
fvgMaxCount = input.int(5, "Max Visible FVGs", minval=1, maxval=20, group=fvgGroup)
fvgMinATRMult = input.float(1.0, "Min Displacement (ATR Multiple)", minval=0.1, maxval=5.0, step=0.1, group=fvgGroup, tooltip="Middle candle must be at least this * ATR to qualify as displacement")
showCE = input.bool(true, "Show Consequent Encroachment (50%)", group=fvgGroup)
showMitigatedFVG = input.bool(false, "Show Mitigated FVGs", group=fvgGroup)
showIFVG = input.bool(true, "Show Inversion FVGs (IFVGs)", group=fvgGroup, tooltip="Mitigated FVGs that flip direction — act as support/resistance from the other side")
ifvgColor = input.color(color.new(#FFD600, 80), "IFVG Fill Color", group=fvgGroup)

// === Balanced Price Range ===
bprGroup = "Balanced Price Range"
showBPR = input.bool(true, "Show BPR Zones", group=bprGroup, tooltip="Where a bullish FVG and bearish FVG overlap — rare but extremely strong level")
bprColor = input.color(color.new(#E040FB, 75), "BPR Fill Color", group=bprGroup)

// === Liquidity ===
liqGroup = "Liquidity"
showLiquidity = input.bool(true, "Show Liquidity Levels", group=liqGroup)
showEQHL = input.bool(true, "Show Equal Highs / Lows", group=liqGroup)
eqTolerance = input.float(0.15, "EQH/EQL Tolerance (%)", minval=0.01, maxval=1.0, step=0.01, group=liqGroup, tooltip="How close swing points must be to count as 'equal'")
showSweeps = input.bool(true, "Show Liquidity Sweeps", group=liqGroup)
sweepRequireWickReject = input.bool(false, "Require Wick Rejection Before Sweep", group=liqGroup, tooltip="Stricter sweep mode: only fires when the previous candle had a rejection wick (long wick, closed away from the extreme) and the current candle sweeps that rejection low/high. Reduces noise significantly")

// === Inducement (IDM) ===
idmGroup = "Inducement (IDM)"
showIDM = input.bool(true, "Show Inducement Levels", group=idmGroup, tooltip="Marks internal swing points that get swept while the higher swing structure remains intact — traps traders into the wrong side before the real move")
idmColor = input.color(color.new(#FF6D00, 0), "IDM Marker Color", group=idmGroup)
idmMaxCount = input.int(5, "Max Visible IDMs", minval=1, maxval=15, group=idmGroup)

// === Premium / Discount ===
pdGroup = "Premium / Discount"
showPD = input.bool(true, "Show Premium/Discount Zones", group=pdGroup)
showEQ = input.bool(true, "Show Equilibrium Line", group=pdGroup)

// === Session Levels ===
slGroup = "Session Levels"
showSessionLevels = input.bool(true, "Show Session Levels", group=slGroup, tooltip="Draw previous day and week highs/lows — key institutional reference levels")
showPDHL = input.bool(true, "Previous Day High / Low", group=slGroup)
showPWHL = input.bool(true, "Previous Week High / Low", group=slGroup)
slPDColor = input.color(color.new(#2196F3, 30), "Previous Day Color", group=slGroup)
slPWColor = input.color(color.new(#E040FB, 30), "Previous Week Color", group=slGroup)

// === Killzones ===
kzGroup = "Killzones & Time"
showKZ = input.bool(true, "Show Killzones", group=kzGroup)
kzAsian = input.bool(false, "Asian KZ (20:00–00:00 EST)", group=kzGroup)
kzLondon = input.bool(true, "London KZ (02:00–05:00 EST)", group=kzGroup)
kzNYAM = input.bool(true, "NY AM KZ (08:30–11:00 EST)", group=kzGroup)
kzNYPM = input.bool(false, "NY PM KZ (13:00–16:00 EST)", group=kzGroup)
kzTransparency = input.int(92, "Killzone Transparency", minval=70, maxval=98, group=kzGroup)

// === Optimal Trade Entry ===
oteGroup = "Optimal Trade Entry (OTE)"
showOTE = input.bool(true, "Show OTE Zones", group=oteGroup, tooltip="Fibonacci 61.8%–78.6% retracement zone after displacement — the ideal entry area")
oteFibHigh = input.float(0.786, "Upper Fib Level", minval=0.5, maxval=0.9, step=0.01, group=oteGroup)
oteFibLow = input.float(0.618, "Lower Fib Level", minval=0.4, maxval=0.85, step=0.01, group=oteGroup)
showOTEFibs = input.bool(true, "Show 50% / 61.8% / 78.6% Lines", group=oteGroup)
oteMaxCount = input.int(3, "Max Visible OTE Zones", minval=1, maxval=10, group=oteGroup)
oteBullColor = input.color(color.new(#00BCD4, 80), "Bullish OTE Fill", group=oteGroup)
oteBearColor = input.color(color.new(#E040FB, 80), "Bearish OTE Fill", group=oteGroup)

// === Signals ===
sigGroup = "Signal Generation"
enableSignals = input.bool(true, "Enable Trade Signals", group=sigGroup, tooltip="Show buy/sell arrows when validated confluence aligns")
minSigScore = input.int(4, "Min Confluence Score for Signal", minval=2, maxval=8, group=sigGroup, tooltip="How many factors must align before a signal fires")
requireHTFAlign = input.bool(true, "Require HTF Alignment", group=sigGroup, tooltip="Only signal in the direction of the higher timeframe")
requireKZActive = input.bool(false, "Require Active Killzone", group=sigGroup, tooltip="Only signal during London/NY sessions")
requireCISD = input.bool(false, "Require CISD Confirmation", group=sigGroup, tooltip="Change in State of Delivery — only fires signal when the candle confirms a shift in delivery direction within the zone. Bullish: close above last down-candle's open. Bearish: close below last up-candle's open. More precise entries but fewer signals")
showSigSL = input.bool(true, "Show Stop Loss Level", group=sigGroup)
showSigTP = input.bool(true, "Show Take Profit Level", group=sigGroup)
sigLongColor = input.color(color.new(#00E676, 0), "Long Signal Color", group=sigGroup)
sigShortColor = input.color(color.new(#FF1744, 0), "Short Signal Color", group=sigGroup)
sigCooldown = input.int(10, "Signal Cooldown (bars)", minval=3, maxval=50, group=sigGroup, tooltip="Minimum bars between signals of the same direction — prevents repeated signals while price sits in a zone")

// === Confluence & Scoring ===
confGroup = "Confluence Scoring"
showConfluence = input.bool(true, "Show Confluence Score", group=confGroup)
minScore = input.int(3, "Minimum Score to Display Setup", minval=1, maxval=7, group=confGroup, tooltip="Setups below this score are hidden")

// === Visuals ===
vizGroup = "Colors & Display"
bullColor = input.color(color.new(#00C853, 0), "Bullish", group=vizGroup)
bearColor = input.color(color.new(#FF1744, 0), "Bearish", group=vizGroup)
fvgBullColor = input.color(color.new(#00C853, 85), "Bullish FVG Fill", group=vizGroup)
fvgBearColor = input.color(color.new(#FF1744, 85), "Bearish FVG Fill", group=vizGroup)
obBullColor = input.color(color.new(#2196F3, 80), "Bullish OB Fill", group=vizGroup)
obBearColor = input.color(color.new(#FF9800, 80), "Bearish OB Fill", group=vizGroup)
sweepColor = input.color(color.new(#FFD600, 0), "Sweep Markers", group=vizGroup)
showInfoPanel = input.bool(true, "Show Info Panel", group=vizGroup)
chartLabelSize = input.string("small", "Chart Label Size", options=["tiny", "small", "normal", "large"], group=vizGroup, tooltip="Size of BOS, CHoCH, OB, EQH/EQL labels on chart")
panelTextSize = input.string("small", "Info Panel Text Size", options=["tiny", "small", "normal", "large"], group=vizGroup)

// ============================================================================
// TYPE DEFINITIONS
// ============================================================================

type Swing
    int idx
    float price
    bool isHigh

type StructureBreak
    int idx
    float price
    string breakType  // "BOS" or "CHoCH"
    bool isBullish
    string level      // "swing" or "internal"
    bool hasDisplacement
    line ln
    label lbl

type OrderBlock
    int startIdx
    int endIdx
    float top
    float bottom
    bool isBullish
    bool hasSweep       // was there a liquidity sweep before?
    bool hasDisplacement // did price leave an FVG after?
    bool mitigated
    int score           // confluence score 0-10
    bool inKillzone
    bool inCorrectZone  // premium/discount alignment
    box bx
    label lbl

type BreakerBlock
    int originIdx       // where the original OB was
    int createdIdx      // bar where the breaker was created — its creation bar must not count as a retest
    float top
    float bottom
    bool isBullish      // flipped direction: bullish breaker = support
    int origScore       // score from the original OB
    bool retested       // has price touched it once?
    bool mitigated      // price traded through it = expired
    box bx
    label lbl

type OTEZone
    int idx
    float legHigh         // top of displacement leg
    float legLow          // bottom of displacement leg
    float zoneTop         // upper OTE boundary (78.6% retrace)
    float zoneBottom      // lower OTE boundary (61.8% retrace)
    float fib50           // 50% level
    bool isBullish        // bullish = buy the dip, bearish = sell the rally
    bool triggered        // has price entered the zone?
    bool invalidated      // price blew through the zone
    bool hasOBOverlap     // does an active OB sit inside the OTE?
    bool hasFVGOverlap    // does an active FVG sit inside the OTE?
    box bx
    line fib50Line
    line fibHighLine
    line fibLowLine
    label lbl

type FVG
    int idx
    float top
    float bottom
    bool isBullish
    float displacementATR  // how many ATRs was the middle candle?
    bool mitigated
    bool inKillzone
    box bx
    line ceLine  // consequent encroachment

type IFVG
    int idx
    float top
    float bottom
    bool isBullish      // flipped: bullish IFVG = support (was bearish FVG)
    bool retested
    bool mitigated
    box bx
    label lbl

type BPR
    int idx
    float top           // top of overlap zone
    float bottom        // bottom of overlap zone
    bool mitigated
    box bx
    label lbl

type Inducement
    int idx              // bar where the internal swing was
    float price          // the internal swing price
    bool isBullish       // bullish IDM = sweep of internal low in bullish trend (trap shorts)
    bool triggered       // has the IDM been swept?
    int triggerIdx       // bar where the sweep happened
    bool expired         // no longer relevant
    line ln              // level line
    label lbl            // marker label

// ============================================================================
// GLOBAL STATE
// ============================================================================

var array<Swing> swingPivots = array.new<Swing>()
var array<Swing> internalPivots = array.new<Swing>()
var array<StructureBreak> structureBreaks = array.new<StructureBreak>()
var array<OrderBlock> orderBlocks = array.new<OrderBlock>()
var array<FVG> fvgList = array.new<FVG>()
var array<BreakerBlock> breakerBlocks = array.new<BreakerBlock>()
var array<OTEZone> oteZones = array.new<OTEZone>()
var array<IFVG> ifvgList = array.new<IFVG>()
var array<BPR> bprList = array.new<BPR>()
var array<Inducement> idmList = array.new<Inducement>()

// Market structure state
// v1.6: pivots establish the levels; breaks are detected in real time on the bar
// where price crosses an unbroken level. The broken flags stop a level from firing twice.
var bool swingBullish = true
var float lastSwingHigh = na
var float lastSwingLow = na
var int lastSwingHighIdx = na
var int lastSwingLowIdx = na
var bool swingHighBroken = false
var bool swingLowBroken = false

var bool internalBullish = true
var float lastInternalHigh = na
var float lastInternalLow = na
var int lastInternalHighIdx = na
var int lastInternalLowIdx = na
var bool internalHighBroken = false
var bool internalLowBroken = false

// ATR for displacement measurement
atrVal = ta.atr(14)

// Session level data (PDH/PDL/PWH/PWL)
[slPDH, slPDL] = request.security(syminfo.tickerid, "D", [high[1], low[1]], lookahead=barmerge.lookahead_on)
[slPWH, slPWL] = request.security(syminfo.tickerid, "W", [high[1], low[1]], lookahead=barmerge.lookahead_on)

// ============================================================================
// UTILITY FUNCTIONS
// ============================================================================

// Size converters
getChartSize() =>
    switch chartLabelSize
        "tiny" => size.tiny
        "small" => size.small
        "normal" => size.normal
        "large" => size.large
        => size.small

getPanelSize() =>
    switch panelTextSize
        "tiny" => size.tiny
        "small" => size.small
        "normal" => size.normal
        "large" => size.large
        => size.small

// ============================================================================
// HIGHER TIMEFRAME STRUCTURE DETECTION
// ============================================================================

calcHTFStructure() =>
    // v1.6: pivots only establish the levels; the break is detected on the HTF bar
    // where price actually crosses an unbroken level, flipping the state on that bar
    var float _prevH = na
    var float _prevL = na
    var bool _hBroken = false
    var bool _lBroken = false
    var bool _bull = true
    var string _lastBrk = "—"

    pivH = ta.pivothigh(high, htfSwingLen, htfSwingLen)
    pivL = ta.pivotlow(low, htfSwingLen, htfSwingLen)

    if not na(pivH)
        _prevH := pivH
        _hBroken := false
    if not na(pivL)
        _prevL := pivL
        _lBroken := false

    float _srcH = requireBodyClose ? close : high
    float _srcL = requireBodyClose ? close : low

    bool _brokeH = not na(_prevH) and not _hBroken and _srcH > _prevH
    bool _brokeL = not na(_prevL) and not _lBroken and _srcL < _prevL

    // Outside bar that takes both sides — resolve in the direction of the close
    if _brokeH and _brokeL
        if close >= open
            _brokeL := false
        else
            _brokeH := false

    if _brokeH
        _lastBrk := _bull ? "BOS ▲" : "CHoCH ▲"
        _bull := true
        _hBroken := true
    if _brokeL
        _lastBrk := _bull ? "CHoCH ▼" : "BOS ▼"
        _bull := false
        _lBroken := true

    [_bull, _lastBrk, _prevH, _prevL]

[htfBull_raw, htfBreak_raw, htfHighLevel, htfLowLevel] = request.security(syminfo.tickerid, htfTimeframe, calcHTFStructure(), lookahead=barmerge.lookahead_off)

htfStructureBullish = useHTF ? htfBull_raw : swingBullish
htfLastBreakStr = useHTF ? htfBreak_raw : "N/A"

htfAligned(bool setupBullish) =>
    not useHTF or (setupBullish and htfStructureBullish) or (not setupBullish and not htfStructureBullish)

// Draw HTF levels on chart
var line htfHighLine = na
var line htfLowLine = na
var label htfHighLabel = na
var label htfLowLabel = na

if useHTF and showHTFStructure and barstate.islast and not na(htfHighLevel) and not na(htfLowLevel)
    line.delete(htfHighLine)
    line.delete(htfLowLine)
    label.delete(htfHighLabel)
    label.delete(htfLowLabel)

    htfHighLine := line.new(bar_index - 60, htfHighLevel, bar_index + 10, htfHighLevel,
         xloc.bar_index, extend.none, color.new(bearColor, 40), line.style_dashed, 2)
    htfHighLabel := label.new(bar_index + 10, htfHighLevel, "HTF High",
         xloc.bar_index, yloc.price, color.new(bearColor, 85),
         label.style_label_left, bearColor, getChartSize())

    htfLowLine := line.new(bar_index - 60, htfLowLevel, bar_index + 10, htfLowLevel,
         xloc.bar_index, extend.none, color.new(bullColor, 40), line.style_dashed, 2)
    htfLowLabel := label.new(bar_index + 10, htfLowLevel, "HTF Low",
         xloc.bar_index, yloc.price, color.new(bullColor, 85),
         label.style_label_left, bullColor, getChartSize())

// Killzone detection
isInKillzone() =>
    nyHour = hour(time, "America/New_York")
    nyMin = minute(time, "America/New_York")
    nyTime = nyHour * 100 + nyMin

    inAsian = kzAsian and nyTime >= 2000
    inLondon = kzLondon and (nyTime >= 200 and nyTime < 500)
    inNYAM = kzNYAM and (nyTime >= 830 and nyTime < 1100)
    inNYPM = kzNYPM and (nyTime >= 1300 and nyTime < 1600)

    inAsian or inLondon or inNYAM or inNYPM

getKZName() =>
    nyHour = hour(time, "America/New_York")
    nyMin = minute(time, "America/New_York")
    nyTime = nyHour * 100 + nyMin

    if kzNYAM and (nyTime >= 830 and nyTime < 1100)
        "NY AM"
    else if kzLondon and (nyTime >= 200 and nyTime < 500)
        "London"
    else if kzNYPM and (nyTime >= 1300 and nyTime < 1600)
        "NY PM"
    else if kzAsian and nyTime >= 2000
        "Asian"
    else
        "Off-Session"

// Premium / Discount detection
isPremium(float price, float rangeHigh, float rangeLow) =>
    eq = (rangeHigh + rangeLow) / 2
    price > eq

isDiscount(float price, float rangeHigh, float rangeLow) =>
    eq = (rangeHigh + rangeLow) / 2
    price < eq

// ============================================================================
// SWING DETECTION
// ============================================================================

swingHighVal = ta.pivothigh(high, swingLen, swingLen)
swingLowVal = ta.pivotlow(low, swingLen, swingLen)

internalHighVal = ta.pivothigh(high, internalLen, internalLen)
internalLowVal = ta.pivotlow(low, internalLen, internalLen)

if not na(swingHighVal)
    newSwing = Swing.new(bar_index - swingLen, swingHighVal, true)
    array.push(swingPivots, newSwing)

    // v1.6: a confirmed pivot establishes the level watched for a real-time break
    lastSwingHigh := swingHighVal
    lastSwingHighIdx := bar_index - swingLen
    swingHighBroken := false

    if showSwings
        label.new(bar_index - swingLen, swingHighVal, "▼", xloc.bar_index, yloc.price,
             color.new(bearColor, 80), label.style_label_down, color.new(bearColor, 30), size.tiny)

if not na(swingLowVal)
    newSwing = Swing.new(bar_index - swingLen, swingLowVal, false)
    array.push(swingPivots, newSwing)

    lastSwingLow := swingLowVal
    lastSwingLowIdx := bar_index - swingLen
    swingLowBroken := false

    if showSwings
        label.new(bar_index - swingLen, swingLowVal, "▲", xloc.bar_index, yloc.price,
             color.new(bullColor, 80), label.style_label_up, color.new(bullColor, 30), size.tiny)

if not na(internalHighVal)
    newSwing = Swing.new(bar_index - internalLen, internalHighVal, true)
    array.push(internalPivots, newSwing)
    lastInternalHigh := internalHighVal
    lastInternalHighIdx := bar_index - internalLen
    internalHighBroken := false

if not na(internalLowVal)
    newSwing = Swing.new(bar_index - internalLen, internalLowVal, false)
    array.push(internalPivots, newSwing)
    lastInternalLow := internalLowVal
    lastInternalLowIdx := bar_index - internalLen
    internalLowBroken := false

// Cap pivot arrays to prevent unbounded growth
while array.size(swingPivots) > 100
    array.shift(swingPivots)
while array.size(internalPivots) > 80
    array.shift(internalPivots)

// ============================================================================
// MARKET STRUCTURE — REAL-TIME BOS / CHoCH DETECTION
// ============================================================================
// v1.6: pivots (above) only establish lastSwingHigh / lastSwingLow. Here we check,
// on every confirmed bar, whether price crossed an unbroken level. The break is
// registered on the bar it actually happens and the trend state flips on that bar.
// requireBodyClose selects close-through (body) vs wick-through breaks.

string sBrkType = "none"
bool sBrkBull = false
float sBrkPrice = na
int sBrkIdx = na
int sBrokenLevelIdx = na

if barstate.isconfirmed
    float srcHigh = requireBodyClose ? close : high
    float srcLow = requireBodyClose ? close : low

    bool brokeHigh = not na(lastSwingHigh) and not swingHighBroken and srcHigh > lastSwingHigh
    bool brokeLow = not na(lastSwingLow) and not swingLowBroken and srcLow < lastSwingLow

    // Outside bar that takes both sides — resolve in the direction of the close
    if brokeHigh and brokeLow
        if close >= open
            brokeLow := false
        else
            brokeHigh := false

    if brokeHigh
        sBrkType := swingBullish ? "BOS" : "CHoCH"
        sBrkBull := true
        sBrkPrice := lastSwingHigh
        sBrkIdx := bar_index
        sBrokenLevelIdx := lastSwingHighIdx
        swingBullish := true
        swingHighBroken := true

    if brokeLow
        sBrkType := swingBullish ? "CHoCH" : "BOS"
        sBrkBull := false
        sBrkPrice := lastSwingLow
        sBrkIdx := bar_index
        sBrokenLevelIdx := lastSwingLowIdx
        swingBullish := false
        swingLowBroken := true

if sBrkType != "none"
    // FIX: breaks are always registered — only the drawings are gated by showStructure,
    // so hiding BOS/CHoCH no longer disables OTE zones or the info panel readout
    line structLine = na
    label structLabel = na
    int lineStartIdx = nz(sBrokenLevelIdx, sBrkIdx > 10 ? sBrkIdx - 10 : 0)

    if showStructure
        // Line runs from where the broken level was established to the candle that broke it
        color lineCol = sBrkBull ? bullColor : bearColor
        structLine := line.new(lineStartIdx, sBrkPrice, sBrkIdx, sBrkPrice,
             xloc.bar_index, extend.none, lineCol, sBrkType == "CHoCH" ? line.style_dashed : line.style_solid, 1)

        // Label at midpoint of the line
        int labelIdx = int(math.avg(lineStartIdx, sBrkIdx))
        color labelCol = sBrkBull ? bullColor : bearColor
        structLabel := label.new(labelIdx, sBrkPrice, sBrkType, xloc.bar_index, yloc.price,
             color.new(labelCol, 90), label.style_label_center, labelCol, getChartSize())

    // Store
    newBreak = StructureBreak.new(sBrkIdx, sBrkPrice, sBrkType, sBrkBull, "swing", false, structLine, structLabel)
    array.push(structureBreaks, newBreak)

    // Cap structure breaks — delete oldest drawings to stay within label/line budget
    while array.size(structureBreaks) > 50
        StructureBreak oldest = array.shift(structureBreaks)
        line.delete(oldest.ln)
        label.delete(oldest.lbl)

    // === CREATE OTE ZONE from displacement leg ===
    // Zones are always tracked (signals use them); drawings are gated by showOTE.
    // v1.6: the leg runs from the opposing swing level to the breaking bar's extreme
    float legH = sBrkBull ? high : lastSwingHigh
    float legL = sBrkBull ? lastSwingLow : low
    if not na(legH) and not na(legL) and legH > legL
        float legRange = legH - legL

        if sBrkBull
            float zTop = legH - legRange * oteFibLow
            float zBot = legH - legRange * oteFibHigh
            float f50  = legH - legRange * 0.5

            bool obOverlap = false
            if array.size(orderBlocks) > 0
                for j = array.size(orderBlocks) - 1 to math.max(array.size(orderBlocks) - 10, 0)
                    OrderBlock ob = array.get(orderBlocks, j)
                    if not ob.mitigated and ob.isBullish
                        if ob.top >= zBot and ob.bottom <= zTop
                            obOverlap := true
                            break

            bool fvgOverlap = false
            if array.size(fvgList) > 0
                for j = array.size(fvgList) - 1 to math.max(array.size(fvgList) - 10, 0)
                    FVG f = array.get(fvgList, j)
                    if not f.mitigated and f.isBullish
                        if f.top >= zBot and f.bottom <= zTop
                            fvgOverlap := true
                            break

            string oteLabel = "OTE"
            if obOverlap and fvgOverlap
                oteLabel := "OTE + OB + FVG"
            else if obOverlap
                oteLabel := "OTE + OB"
            else if fvgOverlap
                oteLabel := "OTE + FVG"

            box oteBox = na
            line f50L = na
            line fHighL = na
            line fLowL = na
            label oteLbl = na
            if showOTE
                oteBox := box.new(sBrkIdx, zTop, bar_index + 15, zBot,
                     color.new(#00BCD4, 40), 1, line.style_dashed, extend.none,
                     xloc.bar_index, oteBullColor)
                if showOTEFibs
                    f50L := line.new(sBrkIdx, f50, bar_index + 15, f50,
                         xloc.bar_index, extend.none, color.new(#00BCD4, 50), line.style_dotted, 1)
                    fHighL := line.new(sBrkIdx, zBot, bar_index + 15, zBot,
                         xloc.bar_index, extend.none, color.new(#00BCD4, 60), line.style_dotted, 1)
                    fLowL := line.new(sBrkIdx, zTop, bar_index + 15, zTop,
                         xloc.bar_index, extend.none, color.new(#00BCD4, 60), line.style_dotted, 1)
                oteLbl := label.new(bar_index + 15, zTop, oteLabel,
                     xloc.bar_index, yloc.price, color.new(#00BCD4, 85),
                     label.style_label_left, color.new(#00BCD4, 0), getChartSize())

            newOTE = OTEZone.new(sBrkIdx, legH, legL, zTop, zBot, f50,
                 true, false, false, obOverlap, fvgOverlap,
                 oteBox, f50L, fHighL, fLowL, oteLbl)
            array.push(oteZones, newOTE)

        else
            float zBot = legL + legRange * oteFibLow
            float zTop = legL + legRange * oteFibHigh
            float f50  = legL + legRange * 0.5

            bool obOverlap = false
            if array.size(orderBlocks) > 0
                for j = array.size(orderBlocks) - 1 to math.max(array.size(orderBlocks) - 10, 0)
                    OrderBlock ob = array.get(orderBlocks, j)
                    if not ob.mitigated and not ob.isBullish
                        if ob.top >= zBot and ob.bottom <= zTop
                            obOverlap := true
                            break

            bool fvgOverlap = false
            if array.size(fvgList) > 0
                for j = array.size(fvgList) - 1 to math.max(array.size(fvgList) - 10, 0)
                    FVG f = array.get(fvgList, j)
                    if not f.mitigated and not f.isBullish
                        if f.top >= zBot and f.bottom <= zTop
                            fvgOverlap := true
                            break

            string oteLabel = "OTE"
            if obOverlap and fvgOverlap
                oteLabel := "OTE + OB + FVG"
            else if obOverlap
                oteLabel := "OTE + OB"
            else if fvgOverlap
                oteLabel := "OTE + FVG"

            box oteBox = na
            line f50L = na
            line fHighL = na
            line fLowL = na
            label oteLbl = na
            if showOTE
                oteBox := box.new(sBrkIdx, zTop, bar_index + 15, zBot,
                     color.new(#E040FB, 40), 1, line.style_dashed, extend.none,
                     xloc.bar_index, oteBearColor)
                if showOTEFibs
                    f50L := line.new(sBrkIdx, f50, bar_index + 15, f50,
                         xloc.bar_index, extend.none, color.new(#E040FB, 50), line.style_dotted, 1)
                    fHighL := line.new(sBrkIdx, zTop, bar_index + 15, zTop,
                         xloc.bar_index, extend.none, color.new(#E040FB, 60), line.style_dotted, 1)
                    fLowL := line.new(sBrkIdx, zBot, bar_index + 15, zBot,
                         xloc.bar_index, extend.none, color.new(#E040FB, 60), line.style_dotted, 1)
                oteLbl := label.new(bar_index + 15, zBot, oteLabel,
                     xloc.bar_index, yloc.price, color.new(#E040FB, 85),
                     label.style_label_left, color.new(#E040FB, 0), getChartSize())

            newOTE = OTEZone.new(sBrkIdx, legH, legL, zTop, zBot, f50,
                 false, false, false, obOverlap, fvgOverlap,
                 oteBox, f50L, fHighL, fLowL, oteLbl)
            array.push(oteZones, newOTE)

// Detect internal structure
var array<StructureBreak> internalBreaks = array.new<StructureBreak>()

if showInternalStructure and barstate.isconfirmed
    // v1.6: same real-time break logic as the swing structure
    float iSrcHigh = requireBodyClose ? close : high
    float iSrcLow = requireBodyClose ? close : low

    bool iBrokeHigh = not na(lastInternalHigh) and not internalHighBroken and iSrcHigh > lastInternalHigh
    bool iBrokeLow = not na(lastInternalLow) and not internalLowBroken and iSrcLow < lastInternalLow

    // Outside bar that takes both sides — resolve in the direction of the close
    if iBrokeHigh and iBrokeLow
        if close >= open
            iBrokeLow := false
        else
            iBrokeHigh := false

    string iBrkType = "none"
    bool iBrkBull = false
    float iBrkPrice = na
    int iBrkIdx = bar_index
    int iBrokenIdx = na

    if iBrokeHigh
        iBrkType := internalBullish ? "BOS" : "CHoCH"
        iBrkBull := true
        iBrkPrice := lastInternalHigh
        iBrokenIdx := lastInternalHighIdx
        internalBullish := true
        internalHighBroken := true

    if iBrokeLow
        iBrkType := internalBullish ? "CHoCH" : "BOS"
        iBrkBull := false
        iBrkPrice := lastInternalLow
        iBrokenIdx := lastInternalLowIdx
        internalBullish := false
        internalLowBroken := true

    if iBrkType != "none"
        color iLineCol = iBrkBull ? color.new(bullColor, 50) : color.new(bearColor, 50)
        int iLineStart = nz(iBrokenIdx, iBrkIdx > 5 ? iBrkIdx - 5 : 0)
        line iLine = line.new(iLineStart, iBrkPrice, iBrkIdx, iBrkPrice,
             xloc.bar_index, extend.none, iLineCol, line.style_dotted, 1)
        int iLabelIdx = int(math.avg(iLineStart, iBrkIdx))
        label iLbl = label.new(iLabelIdx, iBrkPrice, iBrkType, xloc.bar_index, yloc.price,
             color.new(iLineCol, 90), label.style_label_center, iLineCol, getChartSize())

        array.push(internalBreaks, StructureBreak.new(iBrkIdx, iBrkPrice, iBrkType, iBrkBull, "internal", false, iLine, iLbl))

        // Cap internal structure breaks
        while array.size(internalBreaks) > 30
            StructureBreak oldest = array.shift(internalBreaks)
            line.delete(oldest.ln)
            label.delete(oldest.lbl)

// ============================================================================
// INDUCEMENT (IDM) DETECTION
// ============================================================================
// IDM = internal swing point that gets swept while higher-level swing structure
// remains intact. In a bullish swing trend, internal lows are inducement —
// price sweeps them to trap shorts before continuing up. Vice versa for bearish.

// Create new IDM levels from confirmed internal pivots
if showIDM
    // In bullish swing trend: internal lows are inducement targets
    if not na(internalLowVal) and swingBullish
        float idmPrice = internalLowVal
        int idmIdx = bar_index - internalLen
        // Don't create if too close to the swing low itself
        bool tooCloseToSwing = not na(lastSwingLow) and math.abs(idmPrice - lastSwingLow) / idmPrice * 100 < 0.1
        if not tooCloseToSwing
            line idmLine = line.new(idmIdx, idmPrice, bar_index + 10, idmPrice,
                 xloc.bar_index, extend.none, color.new(idmColor, 50), line.style_dotted, 1)
            label idmLbl = label.new(idmIdx, idmPrice, "IDM",
                 xloc.bar_index, yloc.price, color.new(idmColor, 85),
                 label.style_label_up, idmColor, getChartSize())
            newIDM = Inducement.new(idmIdx, idmPrice, true, false, na, false, idmLine, idmLbl)
            array.push(idmList, newIDM)

    // In bearish swing trend: internal highs are inducement targets
    if not na(internalHighVal) and not swingBullish
        float idmPrice = internalHighVal
        int idmIdx = bar_index - internalLen
        bool tooCloseToSwing = not na(lastSwingHigh) and math.abs(idmPrice - lastSwingHigh) / idmPrice * 100 < 0.1
        if not tooCloseToSwing
            line idmLine = line.new(idmIdx, idmPrice, bar_index + 10, idmPrice,
                 xloc.bar_index, extend.none, color.new(idmColor, 50), line.style_dotted, 1)
            label idmLbl = label.new(idmIdx, idmPrice, "IDM",
                 xloc.bar_index, yloc.price, color.new(idmColor, 85),
                 label.style_label_down, idmColor, getChartSize())
            newIDM = Inducement.new(idmIdx, idmPrice, false, false, na, false, idmLine, idmLbl)
            array.push(idmList, newIDM)

// IDM sweep detection + lifecycle management
bool newIDMTriggered = false

if showIDM and array.size(idmList) > 0
    for i = array.size(idmList) - 1 to 0
        Inducement idm = array.get(idmList, i)
        if not idm.expired and not idm.triggered
            // Check if swing structure has flipped — invalidate IDM
            if idm.isBullish and not swingBullish
                // Swing went bearish — bullish IDMs are no longer relevant
                idm.expired := true
                line.delete(idm.ln)
                label.delete(idm.lbl)
            else if not idm.isBullish and swingBullish
                // Swing went bullish — bearish IDMs are no longer relevant
                idm.expired := true
                line.delete(idm.ln)
                label.delete(idm.lbl)
            else
                // Check for sweep: price wicks through the IDM level but closes back
                if idm.isBullish
                    // Bullish IDM: price wicks below internal low then closes above
                    if low < idm.price and close > idm.price
                        idm.triggered := true
                        idm.triggerIdx := bar_index
                        newIDMTriggered := true
                        // Update visuals — change label to show triggered state
                        label.delete(idm.lbl)
                        idm.lbl := label.new(bar_index, low, "IDM ⚡",
                             xloc.bar_index, yloc.price, color.new(idmColor, 70),
                             label.style_label_up, idmColor, getChartSize())
                        // Extend line to sweep bar
                        line.set_x2(idm.ln, bar_index)
                        line.set_style(idm.ln, line.style_solid)
                        line.set_color(idm.ln, color.new(idmColor, 30))
                else
                    // Bearish IDM: price wicks above internal high then closes below
                    if high > idm.price and close < idm.price
                        idm.triggered := true
                        idm.triggerIdx := bar_index
                        newIDMTriggered := true
                        label.delete(idm.lbl)
                        idm.lbl := label.new(bar_index, high, "IDM ⚡",
                             xloc.bar_index, yloc.price, color.new(idmColor, 70),
                             label.style_label_down, idmColor, getChartSize())
                        line.set_x2(idm.ln, bar_index)
                        line.set_style(idm.ln, line.style_solid)
                        line.set_color(idm.ln, color.new(idmColor, 30))

        // Expire triggered IDMs after a while (they've done their job)
        if idm.triggered and not idm.expired
            if bar_index - idm.triggerIdx > 20
                idm.expired := true
                line.delete(idm.ln)
                label.delete(idm.lbl)

        // Clean up expired
        if idm.expired
            array.remove(idmList, i)

    // Cap max IDMs
    while array.size(idmList) > idmMaxCount * 2
        Inducement oldest = array.shift(idmList)
        line.delete(oldest.ln)
        label.delete(oldest.lbl)

// ============================================================================
// FAIR VALUE GAP DETECTION — WITH DISPLACEMENT FILTER
// ============================================================================

// FIX: FVGs are always detected (signals, OTE overlap and BPR use them);
// only the drawings are gated by showFVG
bullFVG_top = low
bullFVG_bot = high[2]
bullFVG_exists = bullFVG_bot < bullFVG_top

midCandleSize = math.abs(close[1] - open[1])
isDisplacement = midCandleSize >= atrVal[1] * fvgMinATRMult

if bullFVG_exists and isDisplacement and close[1] > open[1]
    bool inKZ = isInKillzone()
    newFVG = FVG.new(bar_index - 1, bullFVG_top, bullFVG_bot, true,
         midCandleSize / atrVal[1], false, inKZ, na, na)

    if showFVG
        box fvgBox = box.new(bar_index - 2, bullFVG_top, bar_index + 8, bullFVG_bot,
             bullColor, 1, line.style_solid, extend.none, xloc.bar_index, fvgBullColor)
        newFVG.bx := fvgBox

        if showCE
            float ceLevel = (bullFVG_top + bullFVG_bot) / 2
            line cLine = line.new(bar_index - 2, ceLevel, bar_index + 8, ceLevel,
                 xloc.bar_index, extend.none, color.new(bullColor, 60), line.style_dotted, 1)
            newFVG.ceLine := cLine

    array.push(fvgList, newFVG)

bearFVG_top = low[2]
bearFVG_bot = high
bearFVG_exists = bearFVG_top > bearFVG_bot

if bearFVG_exists and isDisplacement and close[1] < open[1]
    bool inKZ = isInKillzone()
    newFVG = FVG.new(bar_index - 1, bearFVG_top, bearFVG_bot, false,
         midCandleSize / atrVal[1], false, inKZ, na, na)

    if showFVG
        box fvgBox = box.new(bar_index - 2, bearFVG_top, bar_index + 8, bearFVG_bot,
             bearColor, 1, line.style_solid, extend.none, xloc.bar_index, fvgBearColor)
        newFVG.bx := fvgBox

        if showCE
            float ceLevel = (bearFVG_top + bearFVG_bot) / 2
            line cLine = line.new(bar_index - 2, ceLevel, bar_index + 8, ceLevel,
                 xloc.bar_index, extend.none, color.new(bearColor, 60), line.style_dotted, 1)
            newFVG.ceLine := cLine

    array.push(fvgList, newFVG)

// FVG Mitigation + IFVG spawning
bool newBullIFVG = false
bool newBearIFVG = false

if array.size(fvgList) > 0
    for i = array.size(fvgList) - 1 to 0
        FVG f = array.get(fvgList, i)
        if not f.mitigated
            if f.isBullish and close < f.bottom
                f.mitigated := true
                if not showMitigatedFVG
                    box.delete(f.bx)
                    line.delete(f.ceLine)
                else if not na(f.bx)
                    box.set_bgcolor(f.bx, color.new(color.gray, 92))

                if showIFVG
                    newIFVG = IFVG.new(bar_index, f.top, f.bottom, false, false, false, na, na)
                    box ifvgBox = box.new(bar_index, f.top, bar_index + 15, f.bottom,
                         color.new(#FFD600, 40), 1, line.style_dashed, extend.none,
                         xloc.bar_index, ifvgColor)
                    newIFVG.bx := ifvgBox
                    label ifvgLbl = label.new(bar_index, f.top, "IFVG ▼",
                         xloc.bar_index, yloc.price, color.new(#FFD600, 85),
                         label.style_label_down, color.new(#FFD600, 0), getChartSize())
                    newIFVG.lbl := ifvgLbl
                    array.push(ifvgList, newIFVG)
                    newBearIFVG := true

            else if not f.isBullish and close > f.top
                f.mitigated := true
                if not showMitigatedFVG
                    box.delete(f.bx)
                    line.delete(f.ceLine)
                else if not na(f.bx)
                    box.set_bgcolor(f.bx, color.new(color.gray, 92))

                if showIFVG
                    newIFVG = IFVG.new(bar_index, f.top, f.bottom, true, false, false, na, na)
                    box ifvgBox = box.new(bar_index, f.top, bar_index + 15, f.bottom,
                         color.new(#FFD600, 40), 1, line.style_dashed, extend.none,
                         xloc.bar_index, ifvgColor)
                    newIFVG.bx := ifvgBox
                    label ifvgLbl = label.new(bar_index, f.bottom, "IFVG ▲",
                         xloc.bar_index, yloc.price, color.new(#FFD600, 85),
                         label.style_label_up, color.new(#FFD600, 0), getChartSize())
                    newIFVG.lbl := ifvgLbl
                    array.push(ifvgList, newIFVG)
                    newBullIFVG := true

    while array.size(fvgList) > fvgMaxCount * 3
        FVG oldest = array.shift(fvgList)
        box.delete(oldest.bx)
        line.delete(oldest.ceLine)

// ============================================================================
// IFVG MANAGEMENT
// ============================================================================

if array.size(ifvgList) > 0
    for i = array.size(ifvgList) - 1 to 0
        IFVG iv = array.get(ifvgList, i)
        if not iv.mitigated
            bool priceInZone = high >= iv.bottom and low <= iv.top

            // FIX: the bar that created the IFVG always overlaps it — don't count it as a retest
            if priceInZone and not iv.retested and bar_index > iv.idx
                iv.retested := true
                box.set_border_width(iv.bx, 2)

            else if iv.retested
                if iv.isBullish and close < iv.bottom
                    iv.mitigated := true
                    box.delete(iv.bx)
                    label.delete(iv.lbl)
                else if not iv.isBullish and close > iv.top
                    iv.mitigated := true
                    box.delete(iv.bx)
                    label.delete(iv.lbl)

    while array.size(ifvgList) > fvgMaxCount * 2
        IFVG oldest = array.shift(ifvgList)
        box.delete(oldest.bx)
        label.delete(oldest.lbl)

// ============================================================================
// BALANCED PRICE RANGE (BPR)
// ============================================================================

if showBPR and array.size(fvgList) >= 2
    // FIX: lower bound is 1 (not 0) so the inner loop (i - 1) can never index -1
    for i = array.size(fvgList) - 1 to math.max(array.size(fvgList) - 8, 1)
        FVG f1 = array.get(fvgList, i)
        if not f1.mitigated
            for j = i - 1 to math.max(i - 6, 0)
                FVG f2 = array.get(fvgList, j)
                if not f2.mitigated and f1.isBullish != f2.isBullish
                    float overlapTop = math.min(f1.top, f2.top)
                    float overlapBot = math.max(f1.bottom, f2.bottom)

                    if overlapTop > overlapBot
                        bool alreadyExists = false
                        if array.size(bprList) > 0
                            for k = array.size(bprList) - 1 to math.max(array.size(bprList) - 5, 0)
                                BPR existing = array.get(bprList, k)
                                if math.abs(existing.top - overlapTop) < 1 and math.abs(existing.bottom - overlapBot) < 1
                                    alreadyExists := true
                                    break

                        if not alreadyExists
                            int bprIdx = math.max(f1.idx, f2.idx)
                            newBPR = BPR.new(bprIdx, overlapTop, overlapBot, false, na, na)
                            box bprBox = box.new(bprIdx, overlapTop, bar_index + 15, overlapBot,
                                 color.new(#E040FB, 30), 2, line.style_solid, extend.none,
                                 xloc.bar_index, bprColor)
                            newBPR.bx := bprBox
                            label bprLbl = label.new(bprIdx, overlapTop, "BPR ◆",
                                 xloc.bar_index, yloc.price, color.new(#E040FB, 80),
                                 label.style_label_down, color.new(#E040FB, 0), getChartSize())
                            newBPR.lbl := bprLbl
                            array.push(bprList, newBPR)
                    break

if array.size(bprList) > 0
    for i = array.size(bprList) - 1 to 0
        BPR b = array.get(bprList, i)
        if not b.mitigated
            if close > b.top + (b.top - b.bottom) or close < b.bottom - (b.top - b.bottom)
                b.mitigated := true
                box.delete(b.bx)
                label.delete(b.lbl)

    while array.size(bprList) > 5
        BPR oldest = array.shift(bprList)
        box.delete(oldest.bx)
        label.delete(oldest.lbl)

// ============================================================================
// ORDER BLOCK DETECTION — WITH VALIDATION
// ============================================================================

bool newBullOB = false
bool newBearOB = false
int newOBScore = 0

// FIX: OBs are always detected (signals use them); drawings are gated by showOB
if array.size(swingPivots) >= 2
    int sz = array.size(swingPivots)

    // FIX: check both of the last two pivots — handles a swing high and a swing low
    // confirming on the same bar (previously only the last-pushed pivot was processed)
    for k = sz - 2 to sz - 1
        Swing latest = array.get(swingPivots, k)

        if latest.idx == bar_index - swingLen

            // --- BULLISH ORDER BLOCK ---
            if not latest.isHigh
                int obBar = latest.idx
                int candleOffset = bar_index - obBar
                if candleOffset > 0 and candleOffset < 500
                    float obHigh = high[candleOffset]
                    float obLow = low[candleOffset]
                    bool isBearishCandle = close[candleOffset] < open[candleOffset]

                    bool hasSweep = false
                    // Check if OB candle swept any recent swing low
                    if array.size(swingPivots) > 0
                        for j = array.size(swingPivots) - 1 to math.max(0, array.size(swingPivots) - 10)
                            Swing sp = array.get(swingPivots, j)
                            if not sp.isHigh and sp.idx < obBar
                                if obLow < sp.price
                                    hasSweep := true
                                    break

                    // FIX: bullish displacement = a bullish FVG after the OB
                    // (newer low above older high — the condition was previously inverted),
                    // and the loop bound keeps all history offsets >= 0
                    bool hasDisp = false
                    if candleOffset >= 3
                        for j = 0 to math.min(candleOffset - 2, 5)
                            if low[candleOffset - j - 2] > high[candleOffset - j]
                                hasDisp := true
                                break

                    bool inKZ = isInKillzone()

                    bool inCorrectZone = true
                    if not na(lastSwingHigh) and not na(lastSwingLow)
                        inCorrectZone := isDiscount(obLow, lastSwingHigh, lastSwingLow)

                    bool sweepOK = not requireSweep or hasSweep
                    bool dispOK = not requireDisplacement or hasDisp

                    if isBearishCandle and sweepOK and dispOK
                        int score = 0
                        if hasSweep
                            score += 2
                        if hasDisp
                            score += 2
                        if inKZ
                            score += 1
                        if inCorrectZone
                            score += 1
                        if htfAligned(true)
                            score += 2

                        if score >= minScore
                            newOB = OrderBlock.new(obBar, obBar, obHigh, obLow, true,
                                 hasSweep, hasDisp, false, score, inKZ, inCorrectZone, na, na)

                            if showOB
                                box obBox = box.new(obBar, obHigh, bar_index + 5, obLow,
                                     bullColor, 1, line.style_solid, extend.none, xloc.bar_index, obBullColor)
                                newOB.bx := obBox

                                int starCount = score >= 7 ? 5 : score >= 5 ? 4 : score >= 4 ? 3 : score >= 3 ? 2 : 1
                                string stars = starCount >= 5 ? "★★★★★" : starCount >= 4 ? "★★★★" : starCount >= 3 ? "★★★" : starCount >= 2 ? "★★" : "★"
                                label obLabel = label.new(obBar, obLow, "OB " + stars,
                                     xloc.bar_index, yloc.price, color.new(bullColor, 80),
                                     label.style_label_up, bullColor, getChartSize())
                                newOB.lbl := obLabel

                            array.push(orderBlocks, newOB)
                            newBullOB := true
                            newOBScore := score

            // --- BEARISH ORDER BLOCK ---
            if latest.isHigh
                int obBar = latest.idx
                int candleOffset = bar_index - obBar
                if candleOffset > 0 and candleOffset < 500
                    float obHigh = high[candleOffset]
                    float obLow = low[candleOffset]
                    bool isBullishCandle = close[candleOffset] > open[candleOffset]

                    bool hasSweep = false
                    // Check if OB candle swept any recent swing high
                    if array.size(swingPivots) > 0
                        for j = array.size(swingPivots) - 1 to math.max(0, array.size(swingPivots) - 10)
                            Swing sp = array.get(swingPivots, j)
                            if sp.isHigh and sp.idx < obBar
                                if obHigh > sp.price
                                    hasSweep := true
                                    break

                    // FIX: bearish displacement = a bearish FVG after the OB
                    // (newer high below older low — the condition was previously inverted),
                    // and the loop bound keeps all history offsets >= 0
                    bool hasDisp = false
                    if candleOffset >= 3
                        for j = 0 to math.min(candleOffset - 2, 5)
                            if high[candleOffset - j - 2] < low[candleOffset - j]
                                hasDisp := true
                                break

                    bool inKZ = isInKillzone()

                    bool inCorrectZone = true
                    if not na(lastSwingHigh) and not na(lastSwingLow)
                        inCorrectZone := isPremium(obHigh, lastSwingHigh, lastSwingLow)

                    bool sweepOK = not requireSweep or hasSweep
                    bool dispOK = not requireDisplacement or hasDisp

                    if isBullishCandle and sweepOK and dispOK
                        int score = 0
                        if hasSweep
                            score += 2
                        if hasDisp
                            score += 2
                        if inKZ
                            score += 1
                        if inCorrectZone
                            score += 1
                        if htfAligned(false)
                            score += 2

                        if score >= minScore
                            newOB = OrderBlock.new(obBar, obBar, obHigh, obLow, false,
                                 hasSweep, hasDisp, false, score, inKZ, inCorrectZone, na, na)

                            if showOB
                                box obBox = box.new(obBar, obHigh, bar_index + 5, obLow,
                                     bearColor, 1, line.style_solid, extend.none, xloc.bar_index, obBearColor)
                                newOB.bx := obBox

                                int starCount = score >= 7 ? 5 : score >= 5 ? 4 : score >= 4 ? 3 : score >= 3 ? 2 : 1
                                string stars = starCount >= 5 ? "★★★★★" : starCount >= 4 ? "★★★★" : starCount >= 3 ? "★★★" : starCount >= 2 ? "★★" : "★"
                                label obLabel = label.new(obBar, obHigh, "OB " + stars,
                                     xloc.bar_index, yloc.price, color.new(bearColor, 80),
                                     label.style_label_down, bearColor, getChartSize())
                                newOB.lbl := obLabel

                            array.push(orderBlocks, newOB)
                            newBearOB := true
                            newOBScore := score

// OB Mitigation → Breaker Blocks
bool newBullBreaker = false
bool newBearBreaker = false

if array.size(orderBlocks) > 0
    for i = array.size(orderBlocks) - 1 to 0
        OrderBlock ob = array.get(orderBlocks, i)
        if not ob.mitigated
            if ob.isBullish and close < ob.bottom
                ob.mitigated := true
                if not showMitigated
                    box.delete(ob.bx)
                    label.delete(ob.lbl)
                else if not na(ob.bx)
                    box.set_bgcolor(ob.bx, color.new(color.gray, 92))

                // FIX: breakers are always tracked (signals use them); drawings gated by showBreakers
                newBrk = BreakerBlock.new(ob.startIdx, bar_index, ob.top, ob.bottom, false,
                     ob.score, false, false, na, na)
                if showBreakers
                    box brkBox = box.new(bar_index, ob.top, bar_index + 20, ob.bottom,
                         color.new(#FF6D00, 40), 2, line.style_dashed, extend.none,
                         xloc.bar_index, brkBearColor)
                    newBrk.bx := brkBox
                    label brkLbl = label.new(bar_index, ob.top, "BRK ▼",
                         xloc.bar_index, yloc.price, color.new(#FF6D00, 80),
                         label.style_label_down, color.new(#FF6D00, 0), getChartSize())
                    newBrk.lbl := brkLbl
                array.push(breakerBlocks, newBrk)
                newBearBreaker := true

            else if not ob.isBullish and close > ob.top
                ob.mitigated := true
                if not showMitigated
                    box.delete(ob.bx)
                    label.delete(ob.lbl)
                else if not na(ob.bx)
                    box.set_bgcolor(ob.bx, color.new(color.gray, 92))

                // FIX: breakers are always tracked (signals use them); drawings gated by showBreakers
                newBrk = BreakerBlock.new(ob.startIdx, bar_index, ob.top, ob.bottom, true,
                     ob.score, false, false, na, na)
                if showBreakers
                    box brkBox = box.new(bar_index, ob.top, bar_index + 20, ob.bottom,
                         color.new(#00E676, 40), 2, line.style_dashed, extend.none,
                         xloc.bar_index, brkBullColor)
                    newBrk.bx := brkBox
                    label brkLbl = label.new(bar_index, ob.bottom, "BRK ▲",
                         xloc.bar_index, yloc.price, color.new(#00E676, 80),
                         label.style_label_up, color.new(#00E676, 0), getChartSize())
                    newBrk.lbl := brkLbl
                array.push(breakerBlocks, newBrk)
                newBullBreaker := true

    while array.size(orderBlocks) > obMaxCount * 3
        OrderBlock oldest = array.shift(orderBlocks)
        box.delete(oldest.bx)
        label.delete(oldest.lbl)

// ============================================================================
// BREAKER BLOCK MANAGEMENT
// ============================================================================

if array.size(breakerBlocks) > 0
    for i = array.size(breakerBlocks) - 1 to 0
        BreakerBlock brk = array.get(breakerBlocks, i)
        if not brk.mitigated
            bool priceInZone = high >= brk.bottom and low <= brk.top

            // FIX: the candle that created the breaker traverses the zone — don't count
            // the creation bar as a retest (this previously disabled breaker signals)
            if priceInZone and not brk.retested and bar_index > brk.createdIdx
                brk.retested := true
                if not na(brk.bx)
                    box.set_border_width(brk.bx, 3)

            else if brk.retested
                if brk.isBullish and close < brk.bottom
                    brk.mitigated := true
                    box.delete(brk.bx)
                    label.delete(brk.lbl)
                else if not brk.isBullish and close > brk.top
                    brk.mitigated := true
                    box.delete(brk.bx)
                    label.delete(brk.lbl)

    while array.size(breakerBlocks) > brkMaxCount * 2
        BreakerBlock oldest = array.shift(breakerBlocks)
        box.delete(oldest.bx)
        label.delete(oldest.lbl)

// ============================================================================
// OTE ZONE MANAGEMENT
// ============================================================================

if array.size(oteZones) > 0
    for i = array.size(oteZones) - 1 to 0
        OTEZone ote = array.get(oteZones, i)
        if not ote.invalidated
            if ote.isBullish
                if low <= ote.zoneTop and close > ote.zoneBottom and not ote.triggered
                    ote.triggered := true
                    if not na(ote.bx)
                        box.set_border_width(ote.bx, 2)
                if close < ote.legLow
                    ote.invalidated := true
                    box.delete(ote.bx)
                    line.delete(ote.fib50Line)
                    line.delete(ote.fibHighLine)
                    line.delete(ote.fibLowLine)
                    label.delete(ote.lbl)
            else
                if high >= ote.zoneBottom and close < ote.zoneTop and not ote.triggered
                    ote.triggered := true
                    if not na(ote.bx)
                        box.set_border_width(ote.bx, 2)
                if close > ote.legHigh
                    ote.invalidated := true
                    box.delete(ote.bx)
                    line.delete(ote.fib50Line)
                    line.delete(ote.fibHighLine)
                    line.delete(ote.fibLowLine)
                    label.delete(ote.lbl)

    while array.size(oteZones) > oteMaxCount * 2
        OTEZone oldest = array.shift(oteZones)
        box.delete(oldest.bx)
        line.delete(oldest.fib50Line)
        line.delete(oldest.fibHighLine)
        line.delete(oldest.fibLowLine)
        label.delete(oldest.lbl)

// ============================================================================
// LIQUIDITY — EQH / EQL
// ============================================================================

// Track EQH/EQL drawings so they can be capped instead of silently eating the drawing budget
var array<line> eqLines = array.new<line>()
var array<label> eqLabels = array.new<label>()

if showLiquidity and showEQHL and array.size(swingPivots) >= 4
    int sz = array.size(swingPivots)

    // FIX: lower bound is 1 (not 0) so the inner loop (i - 1) can never index -1
    for i = sz - 1 to math.max(sz - 8, 1)
        Swing s1 = array.get(swingPivots, i)
        if s1.isHigh
            for j = i - 1 to math.max(i - 6, 0)
                Swing s2 = array.get(swingPivots, j)
                if s2.isHigh and s1.idx != s2.idx
                    float pctDiff = math.abs(s1.price - s2.price) / s1.price * 100
                    if pctDiff <= eqTolerance
                        if s1.idx == bar_index - swingLen
                            line eqLine = line.new(s2.idx, s2.price, bar_index + 10, s2.price,
                                 xloc.bar_index, extend.none, color.new(sweepColor, 40),
                                 line.style_dotted, 1)
                            label eqLabel = label.new(bar_index + 10, s2.price, "EQH",
                                 xloc.bar_index, yloc.price, color.new(sweepColor, 85),
                                 label.style_label_left, sweepColor, getChartSize())
                            array.push(eqLines, eqLine)
                            array.push(eqLabels, eqLabel)
                        break
        else
            for j = i - 1 to math.max(i - 6, 0)
                Swing s2 = array.get(swingPivots, j)
                if not s2.isHigh and s1.idx != s2.idx
                    float pctDiff = math.abs(s1.price - s2.price) / s1.price * 100
                    if pctDiff <= eqTolerance
                        if s1.idx == bar_index - swingLen
                            line eqLine = line.new(s2.idx, s2.price, bar_index + 10, s2.price,
                                 xloc.bar_index, extend.none, color.new(sweepColor, 40),
                                 line.style_dotted, 1)
                            label eqLabel = label.new(bar_index + 10, s2.price, "EQL",
                                 xloc.bar_index, yloc.price, color.new(sweepColor, 85),
                                 label.style_label_left, sweepColor, getChartSize())
                            array.push(eqLines, eqLine)
                            array.push(eqLabels, eqLabel)
                        break

    // Cap EQH/EQL drawings
    while array.size(eqLines) > 20
        line.delete(array.shift(eqLines))
    while array.size(eqLabels) > 20
        label.delete(array.shift(eqLabels))

// ============================================================================
// LIQUIDITY SWEEP DETECTION
// ============================================================================

if showSweeps and array.size(swingPivots) >= 2
    // Pre-calculate wick rejection on previous candle
    float prevBody = math.abs(close[1] - open[1])
    float prevUpperWick = high[1] - math.max(open[1], close[1])
    float prevLowerWick = math.min(open[1], close[1]) - low[1]
    bool prevHadUpperReject = prevUpperWick > math.max(prevBody, atrVal * 0.1)
    bool prevHadLowerReject = prevLowerWick > math.max(prevBody, atrVal * 0.1)

    for i = array.size(swingPivots) - 1 to math.max(array.size(swingPivots) - 10, 0)
        Swing s = array.get(swingPivots, i)
        if s.isHigh and s.idx < bar_index - 1
            if high > s.price and close < s.price
                bool wickOKBuy = not sweepRequireWickReject or prevHadUpperReject
                if wickOKBuy
                    label.new(bar_index, high, "⚡", xloc.bar_index, yloc.price,
                         color.new(sweepColor, 100), label.style_label_down, sweepColor, getChartSize())
                    break

        if not s.isHigh and s.idx < bar_index - 1
            if low < s.price and close > s.price
                bool wickOKSell = not sweepRequireWickReject or prevHadLowerReject
                if wickOKSell
                    label.new(bar_index, low, "⚡", xloc.bar_index, yloc.price,
                         color.new(sweepColor, 100), label.style_label_up, sweepColor, getChartSize())
                    break

// ============================================================================
// PREMIUM / DISCOUNT ZONES
// ============================================================================

var box pdPremiumBox = na
var box pdDiscountBox = na
var line pdEQLine = na
var label pdEQLabel = na

if showPD and not na(lastSwingHigh) and not na(lastSwingLow) and barstate.islast
    float eq = (lastSwingHigh + lastSwingLow) / 2

    // Delete old drawings
    box.delete(pdPremiumBox)
    box.delete(pdDiscountBox)
    line.delete(pdEQLine)
    label.delete(pdEQLabel)

    if showEQ
        pdEQLine := line.new(bar_index - 40, eq, bar_index + 10, eq,
             xloc.bar_index, extend.none, color.new(color.gray, 50), line.style_dotted, 1)
        pdEQLabel := label.new(bar_index + 10, eq, "EQ", xloc.bar_index, yloc.price,
             color.new(color.gray, 90), label.style_label_left, color.gray, size.tiny)

    pdPremiumBox := box.new(bar_index - 40, lastSwingHigh, bar_index + 10, eq,
         color.new(bearColor, 95), 0, line.style_solid, extend.none,
         xloc.bar_index, color.new(bearColor, 95))

    pdDiscountBox := box.new(bar_index - 40, eq, bar_index + 10, lastSwingLow,
         color.new(bullColor, 95), 0, line.style_solid, extend.none,
         xloc.bar_index, color.new(bullColor, 95))

// ============================================================================
// SESSION LEVELS (PDH/PDL/PWH/PWL)
// ============================================================================

var line slPDHLine = na
var line slPDLLine = na
var line slPWHLine = na
var line slPWLLine = na
var label slPDHLabel = na
var label slPDLLabel = na
var label slPWHLabel = na
var label slPWLLabel = na

if showSessionLevels and barstate.islast
    // Clean up old drawings
    line.delete(slPDHLine)
    line.delete(slPDLLine)
    line.delete(slPWHLine)
    line.delete(slPWLLine)
    label.delete(slPDHLabel)
    label.delete(slPDLLabel)
    label.delete(slPWHLabel)
    label.delete(slPWLLabel)

    if showPDHL and not na(slPDH) and not na(slPDL)
        slPDHLine := line.new(bar_index - 60, slPDH, bar_index + 10, slPDH,
             xloc.bar_index, extend.none, slPDColor, line.style_dashed, 1)
        slPDHLabel := label.new(bar_index + 10, slPDH, "PDH",
             xloc.bar_index, yloc.price, color.new(slPDColor, 85),
             label.style_label_left, slPDColor, getChartSize())
        slPDLLine := line.new(bar_index - 60, slPDL, bar_index + 10, slPDL,
             xloc.bar_index, extend.none, slPDColor, line.style_dashed, 1)
        slPDLLabel := label.new(bar_index + 10, slPDL, "PDL",
             xloc.bar_index, yloc.price, color.new(slPDColor, 85),
             label.style_label_left, slPDColor, getChartSize())

    if showPWHL and not na(slPWH) and not na(slPWL)
        slPWHLine := line.new(bar_index - 60, slPWH, bar_index + 10, slPWH,
             xloc.bar_index, extend.none, slPWColor, line.style_dashed, 2)
        slPWHLabel := label.new(bar_index + 10, slPWH, "PWH",
             xloc.bar_index, yloc.price, color.new(slPWColor, 85),
             label.style_label_left, slPWColor, getChartSize())
        slPWLLine := line.new(bar_index - 60, slPWL, bar_index + 10, slPWL,
             xloc.bar_index, extend.none, slPWColor, line.style_dashed, 2)
        slPWLLabel := label.new(bar_index + 10, slPWL, "PWL",
             xloc.bar_index, yloc.price, color.new(slPWColor, 85),
             label.style_label_left, slPWColor, getChartSize())

// ============================================================================
// KILLZONE BACKGROUND
// ============================================================================

bool currentlyInKZ = isInKillzone()
bgcolor(showKZ and currentlyInKZ ? color.new(color.blue, kzTransparency) : na)

// ============================================================================
// CISD — CHANGE IN STATE OF DELIVERY
// ============================================================================
// Track the last bearish and bullish candle's open price.
// Bullish CISD = current close > last down-candle's open (delivery shifted to buying)
// Bearish CISD = current close < last up-candle's open (delivery shifted to selling)

var float lastBearishOpen = na  // open of the most recent candle where close < open
var float lastBullishOpen = na  // open of the most recent candle where close > open

if close < open
    lastBearishOpen := open
if close > open
    lastBullishOpen := open

bool bullishCISD = not na(lastBearishOpen) and close > lastBearishOpen
bool bearishCISD = not na(lastBullishOpen) and close < lastBullishOpen

// ============================================================================
// SIGNAL GENERATION
// ============================================================================

bool longSignal = false
bool shortSignal = false
int longScore = 0
int shortScore = 0
// FIX: separate long/short SL & TP — a same-bar long + short signal previously
// overwrote each other's levels
float sigLongSL = na
float sigLongTP = na
float sigShortSL = na
float sigShortTP = na

// Persistent signal state for panel display
var string lastSigDirection = "NONE"
var int lastSigScore = 0
var float lastSigSL = na
var float lastSigTP = na
var int lastSigBar = na

var int lastLongBar = na
var int lastShortBar = na

if enableSignals and barstate.isconfirmed
    // ── LONG SIGNAL CHECKS ──
    bool longAtOB = false
    bool longAtFVG = false
    bool longAtOTE = false
    bool longAtBreaker = false
    bool longHTF = htfAligned(true)
    bool longKZ = currentlyInKZ
    bool longDiscount = not na(lastSwingHigh) and not na(lastSwingLow) ? isDiscount(close, lastSwingHigh, lastSwingLow) : false
    bool longStructure = swingBullish
    float bestLongSL = na

    if array.size(orderBlocks) > 0
        for i = array.size(orderBlocks) - 1 to math.max(array.size(orderBlocks) - 10, 0)
            OrderBlock ob = array.get(orderBlocks, i)
            if not ob.mitigated and ob.isBullish
                if low <= ob.top and close > ob.bottom
                    longAtOB := true
                    bestLongSL := math.min(nz(bestLongSL, ob.bottom), ob.bottom)
                    break

    if array.size(fvgList) > 0
        for i = array.size(fvgList) - 1 to math.max(array.size(fvgList) - 10, 0)
            FVG f = array.get(fvgList, i)
            if not f.mitigated and f.isBullish
                if low <= f.top and close > f.bottom
                    longAtFVG := true
                    if na(bestLongSL)
                        bestLongSL := f.bottom
                    break

    if array.size(oteZones) > 0
        for i = array.size(oteZones) - 1 to math.max(array.size(oteZones) - 5, 0)
            OTEZone ote = array.get(oteZones, i)
            if not ote.invalidated and ote.isBullish
                if low <= ote.zoneTop and close > ote.zoneBottom
                    longAtOTE := true
                    if na(bestLongSL)
                        bestLongSL := ote.legLow
                    break

    if array.size(breakerBlocks) > 0
        for i = array.size(breakerBlocks) - 1 to math.max(array.size(breakerBlocks) - 5, 0)
            BreakerBlock brk = array.get(breakerBlocks, i)
            if not brk.mitigated and brk.isBullish and not brk.retested
                if low <= brk.top and close > brk.bottom
                    longAtBreaker := true
                    if na(bestLongSL)
                        bestLongSL := brk.bottom
                    break

    if longAtOB
        longScore += 2
    if longAtFVG
        longScore += 1
    if longAtOTE
        longScore += 2
    if longAtBreaker
        longScore += 1
    if longHTF
        longScore += 1
    if longKZ
        longScore += 1
    if longDiscount
        longScore += 1
    if longStructure
        longScore += 1
    if bullishCISD
        longScore += 1

    bool longTouchingZone = longAtOB or longAtFVG or longAtOTE or longAtBreaker
    bool longHTFOK = not requireHTFAlign or longHTF
    bool longKZOK = not requireKZActive or longKZ
    bool longCISDOK = not requireCISD or bullishCISD

    if longTouchingZone and longScore >= minSigScore and longHTFOK and longKZOK and longCISDOK
        bool longCooldownOK = na(lastLongBar) or (bar_index - lastLongBar) >= sigCooldown
        if longCooldownOK
            longSignal := true
            lastLongBar := bar_index
            sigLongSL := bestLongSL
            // Sanity: SL must be below entry for a long
            if not na(sigLongSL) and sigLongSL >= close
                sigLongSL := na
            // TP = nearest swing high ABOVE current price (not just the last swing high)
            float bestLongTP = na
            if array.size(swingPivots) > 0
                for j = array.size(swingPivots) - 1 to math.max(0, array.size(swingPivots) - 20)
                    Swing sp = array.get(swingPivots, j)
                    if sp.isHigh and sp.price > close
                        if na(bestLongTP) or sp.price < bestLongTP
                            bestLongTP := sp.price
            sigLongTP := bestLongTP
            lastSigDirection := "LONG"
            lastSigScore := longScore
            lastSigSL := sigLongSL
            lastSigTP := sigLongTP
            lastSigBar := bar_index

    // ── SHORT SIGNAL CHECKS ──
    bool shortAtOB = false
    bool shortAtFVG = false
    bool shortAtOTE = false
    bool shortAtBreaker = false
    bool shortHTF = htfAligned(false)
    bool shortKZ = currentlyInKZ
    bool shortPremium = not na(lastSwingHigh) and not na(lastSwingLow) ? isPremium(close, lastSwingHigh, lastSwingLow) : false
    bool shortStructure = not swingBullish
    float bestShortSL = na

    if array.size(orderBlocks) > 0
        for i = array.size(orderBlocks) - 1 to math.max(array.size(orderBlocks) - 10, 0)
            OrderBlock ob = array.get(orderBlocks, i)
            if not ob.mitigated and not ob.isBullish
                if high >= ob.bottom and close < ob.top
                    shortAtOB := true
                    bestShortSL := math.max(nz(bestShortSL, ob.top), ob.top)
                    break

    if array.size(fvgList) > 0
        for i = array.size(fvgList) - 1 to math.max(array.size(fvgList) - 10, 0)
            FVG f = array.get(fvgList, i)
            if not f.mitigated and not f.isBullish
                if high >= f.bottom and close < f.top
                    shortAtFVG := true
                    if na(bestShortSL)
                        bestShortSL := f.top
                    break

    if array.size(oteZones) > 0
        for i = array.size(oteZones) - 1 to math.max(array.size(oteZones) - 5, 0)
            OTEZone ote = array.get(oteZones, i)
            if not ote.invalidated and not ote.isBullish
                if high >= ote.zoneBottom and close < ote.zoneTop
                    shortAtOTE := true
                    if na(bestShortSL)
                        bestShortSL := ote.legHigh
                    break

    if array.size(breakerBlocks) > 0
        for i = array.size(breakerBlocks) - 1 to math.max(array.size(breakerBlocks) - 5, 0)
            BreakerBlock brk = array.get(breakerBlocks, i)
            if not brk.mitigated and not brk.isBullish and not brk.retested
                if high >= brk.bottom and close < brk.top
                    shortAtBreaker := true
                    if na(bestShortSL)
                        bestShortSL := brk.top
                    break

    if shortAtOB
        shortScore += 2
    if shortAtFVG
        shortScore += 1
    if shortAtOTE
        shortScore += 2
    if shortAtBreaker
        shortScore += 1
    if shortHTF
        shortScore += 1
    if shortKZ
        shortScore += 1
    if shortPremium
        shortScore += 1
    if shortStructure
        shortScore += 1
    if bearishCISD
        shortScore += 1

    bool shortTouchingZone = shortAtOB or shortAtFVG or shortAtOTE or shortAtBreaker
    bool shortHTFOK = not requireHTFAlign or shortHTF
    bool shortKZOK = not requireKZActive or shortKZ
    bool shortCISDOK = not requireCISD or bearishCISD

    if shortTouchingZone and shortScore >= minSigScore and shortHTFOK and shortKZOK and shortCISDOK
        bool shortCooldownOK = na(lastShortBar) or (bar_index - lastShortBar) >= sigCooldown
        if shortCooldownOK
            shortSignal := true
            lastShortBar := bar_index
            sigShortSL := bestShortSL
            // Sanity: SL must be above entry for a short
            if not na(sigShortSL) and sigShortSL <= close
                sigShortSL := na
            // TP = nearest swing low BELOW current price (not just the last swing low)
            float bestShortTP = na
            if array.size(swingPivots) > 0
                for j = array.size(swingPivots) - 1 to math.max(0, array.size(swingPivots) - 20)
                    Swing sp = array.get(swingPivots, j)
                    if not sp.isHigh and sp.price < close
                        if na(bestShortTP) or sp.price > bestShortTP
                            bestShortTP := sp.price
            sigShortTP := bestShortTP
            lastSigDirection := "SHORT"
            lastSigScore := shortScore
            lastSigSL := sigShortSL
            lastSigTP := sigShortTP
            lastSigBar := bar_index

// ── PLOT SIGNALS ──
plotshape(longSignal ? low : na, "Long Signal", shape.triangleup, location.belowbar, sigLongColor, size=size.small)
plotshape(shortSignal ? high : na, "Short Signal", shape.triangledown, location.abovebar, sigShortColor, size=size.small)

plotshape(longSignal and showSigSL and not na(sigLongSL) ? sigLongSL : na, "Long SL", shape.xcross, location.absolute, color.new(sigShortColor, 30), size=size.tiny)
plotshape(shortSignal and showSigSL and not na(sigShortSL) ? sigShortSL : na, "Short SL", shape.xcross, location.absolute, color.new(sigShortColor, 30), size=size.tiny)

if longSignal and showSigSL and not na(sigLongSL)
    line.new(bar_index, sigLongSL, bar_index + 8, sigLongSL,
         xloc.bar_index, extend.none, color.new(sigShortColor, 40), line.style_dotted, 1)
    label.new(bar_index + 8, sigLongSL, "SL", xloc.bar_index, yloc.price,
         color.new(sigShortColor, 90), label.style_label_left, sigShortColor, size.tiny)

if longSignal and showSigTP and not na(sigLongTP)
    line.new(bar_index, sigLongTP, bar_index + 8, sigLongTP,
         xloc.bar_index, extend.none, color.new(sigLongColor, 40), line.style_dotted, 1)
    label.new(bar_index + 8, sigLongTP, "TP", xloc.bar_index, yloc.price,
         color.new(sigLongColor, 90), label.style_label_left, sigLongColor, size.tiny)

if shortSignal and showSigSL and not na(sigShortSL)
    line.new(bar_index, sigShortSL, bar_index + 8, sigShortSL,
         xloc.bar_index, extend.none, color.new(sigShortColor, 40), line.style_dotted, 1)
    label.new(bar_index + 8, sigShortSL, "SL", xloc.bar_index, yloc.price,
         color.new(sigShortColor, 90), label.style_label_left, sigShortColor, size.tiny)

if shortSignal and showSigTP and not na(sigShortTP)
    line.new(bar_index, sigShortTP, bar_index + 8, sigShortTP,
         xloc.bar_index, extend.none, color.new(sigLongColor, 40), line.style_dotted, 1)
    label.new(bar_index + 8, sigShortTP, "TP", xloc.bar_index, yloc.price,
         color.new(sigLongColor, 90), label.style_label_left, sigLongColor, size.tiny)

// ============================================================================
// INFO PANEL
// ============================================================================

if showInfoPanel and barstate.islast
    var table panel = table.new(position.top_right, 2, 28,
         bgcolor=color.new(color.black, 85), border_width=1)

    table.cell(panel, 0, 0, "ICT Validated SMC", text_color=color.white, text_size=size.normal)
    table.cell(panel, 1, 0, "v1.6", text_color=color.gray, text_size=getPanelSize())

    table.cell(panel, 0, 1, "Structure:", text_color=color.gray, text_size=getPanelSize())
    string structText = swingBullish ? "BULLISH" : "BEARISH"
    color structCol = swingBullish ? bullColor : bearColor
    table.cell(panel, 1, 1, structText, text_color=structCol, text_size=getPanelSize())

    table.cell(panel, 0, 2, "Last Break:", text_color=color.gray, text_size=getPanelSize())
    string lastBreakText = "—"
    color lastBreakCol = color.gray
    if array.size(structureBreaks) > 0
        StructureBreak lastBrk = array.get(structureBreaks, array.size(structureBreaks) - 1)
        lastBreakText := lastBrk.breakType + (lastBrk.isBullish ? " ▲" : " ▼")
        lastBreakCol := lastBrk.isBullish ? bullColor : bearColor
    table.cell(panel, 1, 2, lastBreakText, text_color=lastBreakCol, text_size=getPanelSize())

    table.cell(panel, 0, 3, "HTF (" + htfTimeframe + "):", text_color=color.gray, text_size=getPanelSize())
    if useHTF
        string htfText = htfStructureBullish ? "BULLISH" : "BEARISH"
        color htfCol = htfStructureBullish ? bullColor : bearColor
        table.cell(panel, 1, 3, htfText, text_color=htfCol, text_size=getPanelSize())
    else
        table.cell(panel, 1, 3, "DISABLED", text_color=color.gray, text_size=getPanelSize())

    table.cell(panel, 0, 4, "HTF Break:", text_color=color.gray, text_size=getPanelSize())
    if useHTF
        color htfBrkCol = str.contains(htfLastBreakStr, "▲") ? bullColor : str.contains(htfLastBreakStr, "▼") ? bearColor : color.gray
        table.cell(panel, 1, 4, htfLastBreakStr, text_color=htfBrkCol, text_size=getPanelSize())
    else
        table.cell(panel, 1, 4, "—", text_color=color.gray, text_size=getPanelSize())

    table.cell(panel, 0, 5, "Alignment:", text_color=color.gray, text_size=getPanelSize())
    if useHTF
        bool aligned = (swingBullish and htfStructureBullish) or (not swingBullish and not htfStructureBullish)
        string alignText = aligned ? "✓ ALIGNED" : "✗ COUNTER-TREND"
        color alignCol = aligned ? bullColor : bearColor
        table.cell(panel, 1, 5, alignText, text_color=alignCol, text_size=getPanelSize())
    else
        table.cell(panel, 1, 5, "—", text_color=color.gray, text_size=getPanelSize())

    table.cell(panel, 0, 6, "Active OBs:", text_color=color.gray, text_size=getPanelSize())
    int activeOBs = 0
    if array.size(orderBlocks) > 0
        for i = 0 to array.size(orderBlocks) - 1
            OrderBlock ob = array.get(orderBlocks, i)
            if not ob.mitigated
                activeOBs += 1
    table.cell(panel, 1, 6, str.tostring(activeOBs), text_color=color.white, text_size=getPanelSize())

    table.cell(panel, 0, 7, "Breakers:", text_color=color.gray, text_size=getPanelSize())
    int activeBreakers = 0
    if array.size(breakerBlocks) > 0
        for i = 0 to array.size(breakerBlocks) - 1
            BreakerBlock brk = array.get(breakerBlocks, i)
            if not brk.mitigated
                activeBreakers += 1
    table.cell(panel, 1, 7, str.tostring(activeBreakers), text_color=activeBreakers > 0 ? color.orange : color.white, text_size=getPanelSize())

    table.cell(panel, 0, 8, "OTE Zones:", text_color=color.gray, text_size=getPanelSize())
    int activeOTEs = 0
    if array.size(oteZones) > 0
        for i = 0 to array.size(oteZones) - 1
            OTEZone ote = array.get(oteZones, i)
            if not ote.invalidated
                activeOTEs += 1
    string oteStr = str.tostring(activeOTEs)
    bool hasTriple = false
    if array.size(oteZones) > 0
        for i = 0 to array.size(oteZones) - 1
            OTEZone ote = array.get(oteZones, i)
            if not ote.invalidated and ote.hasOBOverlap and ote.hasFVGOverlap
                hasTriple := true
                break
    if hasTriple
        oteStr := oteStr + " ◆"
    color oteCol = hasTriple ? color.aqua : activeOTEs > 0 ? color.white : color.gray
    table.cell(panel, 1, 8, oteStr, text_color=oteCol, text_size=getPanelSize())

    table.cell(panel, 0, 9, "Active FVGs:", text_color=color.gray, text_size=getPanelSize())
    int activeFVGs = 0
    if array.size(fvgList) > 0
        for i = 0 to array.size(fvgList) - 1
            FVG f = array.get(fvgList, i)
            if not f.mitigated
                activeFVGs += 1
    table.cell(panel, 1, 9, str.tostring(activeFVGs), text_color=color.white, text_size=getPanelSize())

    table.cell(panel, 0, 10, "IFVGs:", text_color=color.gray, text_size=getPanelSize())
    int activeIFVGs = 0
    if array.size(ifvgList) > 0
        for i = 0 to array.size(ifvgList) - 1
            IFVG iv = array.get(ifvgList, i)
            if not iv.mitigated
                activeIFVGs += 1
    table.cell(panel, 1, 10, str.tostring(activeIFVGs), text_color=activeIFVGs > 0 ? color.new(#FFD600, 0) : color.white, text_size=getPanelSize())

    table.cell(panel, 0, 11, "BPRs:", text_color=color.gray, text_size=getPanelSize())
    int activeBPRs = 0
    if array.size(bprList) > 0
        for i = 0 to array.size(bprList) - 1
            BPR b = array.get(bprList, i)
            if not b.mitigated
                activeBPRs += 1
    table.cell(panel, 1, 11, activeBPRs > 0 ? str.tostring(activeBPRs) + " ◆" : "0",
         text_color=activeBPRs > 0 ? color.new(#E040FB, 0) : color.gray, text_size=getPanelSize())

    // IDM count
    table.cell(panel, 0, 12, "IDMs:", text_color=color.gray, text_size=getPanelSize())
    int activeIDMs = 0
    int triggeredIDMs = 0
    if array.size(idmList) > 0
        for i = 0 to array.size(idmList) - 1
            Inducement idm = array.get(idmList, i)
            if not idm.expired
                activeIDMs += 1
                if idm.triggered
                    triggeredIDMs += 1
    string idmStr = str.tostring(activeIDMs)
    if triggeredIDMs > 0
        idmStr := idmStr + " (" + str.tostring(triggeredIDMs) + " ⚡)"
    table.cell(panel, 1, 12, idmStr, text_color=activeIDMs > 0 ? idmColor : color.gray, text_size=getPanelSize())

    // Zone
    table.cell(panel, 0, 13, "Zone:", text_color=color.gray, text_size=getPanelSize())
    string zoneText = "—"
    color zoneCol = color.gray
    if not na(lastSwingHigh) and not na(lastSwingLow)
        if isPremium(close, lastSwingHigh, lastSwingLow)
            zoneText := "PREMIUM"
            zoneCol := bearColor
        else
            zoneText := "DISCOUNT"
            zoneCol := bullColor
    table.cell(panel, 1, 13, zoneText, text_color=zoneCol, text_size=getPanelSize())

    table.cell(panel, 0, 14, "Session:", text_color=color.gray, text_size=getPanelSize())
    string sessionName = getKZName()
    color sessionCol = currentlyInKZ ? color.aqua : color.gray
    table.cell(panel, 1, 14, sessionName, text_color=sessionCol, text_size=getPanelSize())

    table.cell(panel, 0, 15, "Killzone:", text_color=color.gray, text_size=getPanelSize())
    string kzStatus = currentlyInKZ ? "ACTIVE" : "INACTIVE"
    color kzCol = currentlyInKZ ? bullColor : color.gray
    table.cell(panel, 1, 15, kzStatus, text_color=kzCol, text_size=getPanelSize())

    table.cell(panel, 0, 16, "─── VALIDATION ───", text_color=color.aqua, text_size=getPanelSize())
    table.cell(panel, 1, 16, "", text_size=getPanelSize())

    table.cell(panel, 0, 17, "OB Sweep:", text_color=color.gray, text_size=getPanelSize())
    table.cell(panel, 1, 17, requireSweep ? "REQUIRED" : "OPTIONAL",
         text_color=requireSweep ? bullColor : color.yellow, text_size=getPanelSize())

    table.cell(panel, 0, 18, "OB Displace:", text_color=color.gray, text_size=getPanelSize())
    table.cell(panel, 1, 18, requireDisplacement ? "REQUIRED" : "OPTIONAL",
         text_color=requireDisplacement ? bullColor : color.yellow, text_size=getPanelSize())

    table.cell(panel, 0, 19, "HTF Check:", text_color=color.gray, text_size=getPanelSize())
    table.cell(panel, 1, 19, useHTF ? htfTimeframe : "OFF",
         text_color=useHTF ? bullColor : color.gray, text_size=getPanelSize())

    table.cell(panel, 0, 20, "FVG Filter:", text_color=color.gray, text_size=getPanelSize())
    table.cell(panel, 1, 20, str.tostring(fvgMinATRMult, "#.#") + "x ATR",
         text_color=color.white, text_size=getPanelSize())

    table.cell(panel, 0, 21, "Min Score:", text_color=color.gray, text_size=getPanelSize())
    table.cell(panel, 1, 21, str.tostring(minScore) + " / 8",
         text_color=color.white, text_size=getPanelSize())

    table.cell(panel, 0, 22, "Best OB:", text_color=color.gray, text_size=getPanelSize())
    int bestScore = 0
    if array.size(orderBlocks) > 0
        for i = 0 to array.size(orderBlocks) - 1
            OrderBlock ob = array.get(orderBlocks, i)
            if not ob.mitigated and ob.score > bestScore
                bestScore := ob.score
    int bestStars = bestScore >= 7 ? 5 : bestScore >= 5 ? 4 : bestScore >= 4 ? 3 : bestScore >= 3 ? 2 : bestScore > 0 ? 1 : 0
    string bestStarStr = bestStars >= 5 ? "★★★★★" : bestStars >= 4 ? "★★★★☆" : bestStars >= 3 ? "★★★☆☆" : bestStars >= 2 ? "★★☆☆☆" : bestStars >= 1 ? "★☆☆☆☆" : "—"
    color starCol = bestStars >= 4 ? bullColor : bestStars >= 3 ? color.yellow : bestStars >= 1 ? bearColor : color.gray
    table.cell(panel, 1, 22, bestStarStr, text_color=starCol, text_size=getPanelSize())

    table.cell(panel, 0, 23, "─── SIGNALS ───", text_color=color.aqua, text_size=getPanelSize())
    table.cell(panel, 1, 23, enableSignals ? "ON" : "OFF",
         text_color=enableSignals ? bullColor : color.gray, text_size=getPanelSize())

    table.cell(panel, 0, 24, "Signal:", text_color=color.gray, text_size=getPanelSize())
    if lastSigDirection == "LONG" and not na(lastSigBar)
        int barsAgo = bar_index - lastSigBar
        string lScoreStr = str.tostring(lastSigScore) + "/11"
        string agoStr = barsAgo == 0 ? " (NOW)" : " (" + str.tostring(barsAgo) + " bars ago)"
        table.cell(panel, 1, 24, "▲ LONG " + lScoreStr + agoStr, text_color=sigLongColor, text_size=getPanelSize())
    else if lastSigDirection == "SHORT" and not na(lastSigBar)
        int barsAgo = bar_index - lastSigBar
        string sScoreStr = str.tostring(lastSigScore) + "/11"
        string agoStr = barsAgo == 0 ? " (NOW)" : " (" + str.tostring(barsAgo) + " bars ago)"
        table.cell(panel, 1, 24, "▼ SHORT " + sScoreStr + agoStr, text_color=sigShortColor, text_size=getPanelSize())
    else
        table.cell(panel, 1, 24, "NO SIGNAL", text_color=color.gray, text_size=getPanelSize())

    table.cell(panel, 0, 25, "SL / TP:", text_color=color.gray, text_size=getPanelSize())
    if lastSigDirection != "NONE" and not na(lastSigSL)
        string slStr = str.tostring(lastSigSL, format.mintick)
        string tpStr = not na(lastSigTP) ? str.tostring(lastSigTP, format.mintick) : "—"
        table.cell(panel, 1, 25, slStr + " / " + tpStr,
             text_color=color.white, text_size=getPanelSize())
    else
        table.cell(panel, 1, 25, "— / —", text_color=color.gray, text_size=getPanelSize())

    table.cell(panel, 0, 26, "CISD:", text_color=color.gray, text_size=getPanelSize())
    if bullishCISD and bearishCISD
        table.cell(panel, 1, 26, "▲ BULL + ▼ BEAR", text_color=color.yellow, text_size=getPanelSize())
    else if bullishCISD
        table.cell(panel, 1, 26, "▲ BULLISH", text_color=bullColor, text_size=getPanelSize())
    else if bearishCISD
        table.cell(panel, 1, 26, "▼ BEARISH", text_color=bearColor, text_size=getPanelSize())
    else
        table.cell(panel, 1, 26, "—", text_color=color.gray, text_size=getPanelSize())

// ============================================================================
// ALERTS
// ============================================================================

alertcondition(sBrkType == "CHoCH" and sBrkBull, title="Bullish CHoCH", message="ICT-V: Bullish Change of Character detected")
alertcondition(sBrkType == "CHoCH" and not sBrkBull, title="Bearish CHoCH", message="ICT-V: Bearish Change of Character detected")
alertcondition(sBrkType == "BOS" and sBrkBull, title="Bullish BOS", message="ICT-V: Bullish Break of Structure")
alertcondition(sBrkType == "BOS" and not sBrkBull, title="Bearish BOS", message="ICT-V: Bearish Break of Structure")
alertcondition(newBullOB, title="Bullish OB Formed", message="ICT-V: Validated Bullish Order Block detected — check confluence score")
alertcondition(newBearOB, title="Bearish OB Formed", message="ICT-V: Validated Bearish Order Block detected — check confluence score")
alertcondition(newBullOB and newOBScore >= 5, title="High-Score Bullish OB", message="ICT-V: High-confluence Bullish OB (5+ score) — strong setup")
alertcondition(newBearOB and newOBScore >= 5, title="High-Score Bearish OB", message="ICT-V: High-confluence Bearish OB (5+ score) — strong setup")
alertcondition(newBullBreaker, title="Bullish Breaker", message="ICT-V: Bullish Breaker Block formed — failed bearish OB flipped to support")
alertcondition(newBearBreaker, title="Bearish Breaker", message="ICT-V: Bearish Breaker Block formed — failed bullish OB flipped to resistance")
alertcondition(newIDMTriggered, title="Inducement Swept", message="ICT-V: Inducement level swept — internal swing taken out while higher structure holds")
alertcondition(newBullIFVG, title="Bullish IFVG Formed", message="ICT-V: Bullish Inversion FVG formed — old bearish FVG flipped to support")
alertcondition(newBearIFVG, title="Bearish IFVG Formed", message="ICT-V: Bearish Inversion FVG formed — old bullish FVG flipped to resistance")
alertcondition(longSignal, title="Validated Long Signal", message="ICT-V: Validated LONG signal — check panel for confluence score")
alertcondition(shortSignal, title="Validated Short Signal", message="ICT-V: Validated SHORT signal — check panel for confluence score")